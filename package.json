    "node": ">=18"
  },
  "files": [
    "bin/",
    "dist/",
    "docs/",
    "examples/",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md"
  ],
  "dependencies": {
    "@openai/codex-sdk": "0.134.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
